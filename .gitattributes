# Binary assets route through Git LFS going forward.
#
# The images and Unreal assets already committed to this repository's
# history are raw blobs, not LFS pointers — this file does not rewrite that
# history (a history rewrite invalidates every existing clone and fork).
# It takes effect on the NEXT commit that adds or modifies a matching path.

*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text

# Normalize line endings for text sources so a Windows checkout and a Linux
# CI checkout compare identically.
*.cpp text eol=lf
*.h text eol=lf
*.cs text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
